{
  "name": "3wa-eventhub",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm --filter @eventhub/backend build && pnpm --filter @eventhub/frontend build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
